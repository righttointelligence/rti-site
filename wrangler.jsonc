{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "free-intelligence",
  "compatibility_date": "2026-06-30",
  // Static SPA plus a tiny API for action logging.
  "main": "./worker.ts",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    // Keep 0 unless importing a real historical action count.
    "ACTION_COUNT_OFFSET": "0"
  },
  "d1_databases": [
    {
      "binding": "ACTIONS_DB",
      "database_name": "free_intelligence_actions",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "./migrations"
    }
  ]
}
