{
  "name": "rti-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "bun run build && wrangler d1 migrations apply rti_actions --local && wrangler dev --local --port 8787",
    "dev:worker": "bun run build && wrangler d1 migrations apply rti_actions --local && wrangler dev --local",
    "data:legislators": "bun run tools/civic-data/import-openstates-legislators.ts",
    "data:boundaries:manifest": "bun run tools/civic-data/write-census-boundary-manifest.ts",
    "data:boundaries": "bun run tools/civic-data/build-census-districts.ts",
    "data:runtime-assets": "bun run tools/civic-data/copy-runtime-assets.ts",
    "data:verify:openstates": "bun run tools/civic-data/verify-openstates-geo.ts",
    "build": "tsc -b && vite build && bun run data:runtime-assets",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router-dom": "7.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.13",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "d3-geo": "^3.1.1",
    "i18n-iso-countries": "^7.14.0",
    "tailwindcss": "4.1.13",
    "topojson-client": "^3.1.0",
    "typescript": "5.9.2",
    "vite": "7.1.4",
    "world-atlas": "^2.0.2",
    "wrangler": "4.103.0"
  }
}
