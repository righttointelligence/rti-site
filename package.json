{
  "name": "free-intelligence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler d1 migrations apply free_intelligence_actions --local && wrangler dev --local --port 8787",
    "dev:worker": "bun run build && wrangler d1 migrations apply free_intelligence_actions --local && wrangler dev --local",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router-dom": "7.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.13",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "tailwindcss": "4.1.13",
    "typescript": "5.9.2",
    "vite": "7.1.4",
    "wrangler": "4.103.0"
  }
}
